# Copy to .env and fill in values — never commit .env

# ── LLM (at least one recommended) ───────────────────────────────────────────
# Priority: OpenAI → Anthropic → local Ollama
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model override (auto-selected from key above if blank)
# STASIS_MODEL=gpt-4o-mini

# Ollama endpoint (used as fallback when no cloud key is set)
OLLAMA_BASE=http://127.0.0.1:11434

# ── Identity ──────────────────────────────────────────────────────────────────
USER_NAME=User

# ── TTS voice ─────────────────────────────────────────────────────────────────
# OpenAI voice (used when no cloned voice sample exists)
# Options: alloy  echo  fable  onyx  nova  shimmer
OPENAI_VOICE=nova

# Fish Audio (alternative cloud TTS, higher quality voice cloning)
FISH_API_KEY=
FISH_VOICE_ID=

# pyttsx3 speech rate (words per minute)
VOICE_RATE=185

# ── Voice cloning (Coqui XTTS v2) ────────────────────────────────────────────
# No keys needed — run from web UI: Settings → Train My Voice
# Requires: pip install TTS  +  winget install ffmpeg
# Model (~1.8 GB) downloads automatically on first use

# ── Discord bot ───────────────────────────────────────────────────────────────
# https://discord.com/developers/applications → Bot → Reset Token
DISCORD_BOT_TOKEN=

# Optional: bot responds to ALL messages in this channel (not just @mentions)
# Right-click channel → Copy Channel ID (enable Developer Mode first)
# DISCORD_CHANNEL_ID=
